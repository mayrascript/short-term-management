{
  "name": "short-term-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "playwright test",
    "test:all": "pnpm test && pnpm test:rules && pnpm test:e2e",
    "check-tests": "node scripts/check-tests.mjs --staged",
    "skills:install": "skills add ./skills --skill '*' -a claude-code -a codex -a cursor -a antigravity -y --copy",
    "skills:add": "skills add",
    "skills:check": "node scripts/check-skills.mjs",
    "sync-skills": "pnpm skills:install",
    "postinstall": "node scripts/check-skills.mjs --bootstrap || true",
    "prepare": "husky",
    "diagrams:check": "./scripts/check-diagrams.sh",
    "ui:check": "./scripts/check-ui-guidelines.sh",
    "firestore:check": "./scripts/check-firestore-guidelines.sh"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^1.7.0",
    "mongoose": "^9.4.1",
    "next": "16.2.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "firebase": "^11.2.0",
    "firebase-tools": "^15.13.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "skills": "^1.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
